# Virtual environment
venv/
env/
*.venv

# Python cache
__pycache__/
*.pyc
*.pyo

# Dataset — never push raw or processed data
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Trained model weights
checkpoints/*.pt
checkpoints/*.pth
!checkpoints/.gitkeep

# Generated outputs
outputs/logs/*
outputs/metrics/*
outputs/heatmaps/*
!outputs/logs/.gitkeep
!outputs/metrics/.gitkeep
!outputs/heatmaps/.gitkeep

# Editor / OS clutter
.vscode/
.idea/
.DS_Store
Thumbs.db

# Secrets
.env